PORT=4001
NODE_ENV=development
LOG_LEVEL=info

DB_HOST=localhost
DB_PORT=5442
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=auth_db

# defaults to infra/keys/jwt-public.pem resolved from process.cwd() — override only
# if running from somewhere other than the workspace root
# JWT_PUBLIC_KEY_PATH=infra/keys/jwt-public.pem
# TODO: needed once AuthService signs access tokens (auth.service.ts)
# JWT_PRIVATE_KEY_PATH=infra/keys/jwt-private.pem

# TODO: needed once refresh-token rotation + login lockout are implemented (auth.service.ts)
# REDIS_URL=redis://localhost:6390

# defaults to http://localhost:4318/v1/traces — override to point at a non-local Jaeger
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
