{
  "name": "@booking-platform/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "infra:logs": "docker compose -f infra/docker-compose.yml logs -f",
    "dev": "nx run-many -t serve --parallel=7",
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "lint": "nx run-many -t lint",
    "seed:admin": "ts-node -r tsconfig-paths/register --project apps/auth-service/tsconfig.app.json apps/auth-service/src/seed-admin.ts",
    "migration:generate:auth": "typeorm-ts-node-commonjs migration:generate -d apps/auth-service/src/data-source.ts apps/auth-service/src/migrations/Migration",
    "migration:run:auth": "typeorm-ts-node-commonjs migration:run -d apps/auth-service/src/data-source.ts",
    "migration:generate:event": "typeorm-ts-node-commonjs migration:generate -d apps/event-service/src/data-source.ts apps/event-service/src/migrations/Migration",
    "migration:run:event": "typeorm-ts-node-commonjs migration:run -d apps/event-service/src/data-source.ts",
    "migration:generate:booking": "typeorm-ts-node-commonjs migration:generate -d apps/booking-service/src/data-source.ts apps/booking-service/src/migrations/Migration",
    "migration:run:booking": "typeorm-ts-node-commonjs migration:run -d apps/booking-service/src/data-source.ts",
    "migration:generate:payment": "typeorm-ts-node-commonjs migration:generate -d apps/payment-service/src/data-source.ts apps/payment-service/src/migrations/Migration",
    "migration:run:payment": "typeorm-ts-node-commonjs migration:run -d apps/payment-service/src/data-source.ts",
    "load-test:booking": "k6 run infra/k6/booking-race-condition.js",
    "prepare": "husky"
  },
  "private": true,
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/esbuild": "23.0.1",
    "@nx/eslint": "23.0.1",
    "@nx/eslint-plugin": "23.0.1",
    "@nx/jest": "23.0.1",
    "@nx/js": "^23.0.1",
    "@nx/nest": "23.0.1",
    "@nx/node": "^23.0.1",
    "@nx/web": "23.0.1",
    "@nx/webpack": "23.0.1",
    "@nx/workspace": "23.0.1",
    "@swc/helpers": "~0.5.18",
    "@testcontainers/postgresql": "^12.0.4",
    "@testcontainers/redis": "^12.0.4",
    "@types/amqplib": "^0.10.8",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "~30.0.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.1",
    "@types/passport-jwt": "^4.0.1",
    "esbuild": "^0.27.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "husky": "^9.1.7",
    "jest": "~30.3.0",
    "jest-environment-jsdom": "~30.3.0",
    "jest-environment-node": "~30.3.0",
    "jest-util": "~30.3.0",
    "lint-staged": "^17.0.8",
    "nx": "23.0.1",
    "prettier": "~3.6.2",
    "testcontainers": "^12.0.4",
    "ts-jest": "^29.4.0",
    "ts-node": "10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "webpack": "^5.101.3",
