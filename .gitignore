testem.log
/typings

# System Files
.DS_Store
Thumbs.db

.nx/cache
.nx/workspace-data
.nx/migrate-runs

.nx/polygraph

# secrets — never commit private keys or resolved env files
infra/keys/*.pem
.env
.env.*
!.env.example

# AI assistant config — local only
.claude/
CLAUDE.md
